{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "iCoding Client",
  "version": "0.1.0",
  "identifier": "com.icoding.icoding-client",
  "build": {
    "frontendDist": "frontend-dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "iCoding Client",
        "width": 1227,
        "height": 680,
        "minWidth": 760,
        "minHeight": 560,
        "visible": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/icon.png",
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
